# Copier ce fichier en .env et remplir les valeurs pour le dev local
# NE JAMAIS committer .env dans git

# Azure Key Vault (prod -- laisse vide pour utiliser les variables ci-dessous)
KEY_VAULT_NAME=kv-dtpf-prod

# PostgreSQL -- fallback dev local (si KEY_VAULT_NAME est vide)
PG_HOST=psql-dtpf-psql-prod.postgres.database.azure.com
PG_PORT=5432
PG_DB=dtpf_sylob_prod
PG_USER=
PG_PASSWORD=

# Répertoire des fichiers sources Excel (relatif à la racine du projet)
DATA_DIR=Service_Achat

# Cle API ecriture ERP (header X-API-Key) -- generer : python -c "import secrets;print(secrets.token_urlsafe(32))"
API_KEY=
API_HOST=127.0.0.1
API_PORT=5050

# --- Fetch PJ Gmail (Plan A : src/scripts/gmail/fetch_attachments.py) ---
# Boite ciblee = poste Marlene (en copie quasi-systematique des fils fournisseurs).
GMAIL_LABEL=Achats/Fournisseurs
GMAIL_CREDENTIALS_PATH=config/credentials.json
GMAIL_TOKEN_PATH=config/token.json
# Destination des PJ. Test = local ; prod = partage reseau (echapper les antislashs) :
# GMAIL_PJ_DIR=\\Srv-files-pom\partage\ADA\METIER\SUIVI CDES IMPORT\PJ
GMAIL_PJ_DIR=data/PJ
GMAIL_SINCE=2025-09-01
