# Copier ce fichier en .env et remplir les valeurs pour le dev local
# NE JAMAIS committer .env dans git

# Azure Key Vault (prod — laisse vide pour utiliser les variables ci-dessous)
KEY_VAULT_NAME=kv-dtpf-prod

# PostgreSQL — fallback dev local (si KEY_VAULT_NAME est vide)
PG_HOST=psql-dtpf-psql-prod.postgres.database.azure.com
PG_PORT=5432
PG_DB=dtpf_sylob_prod
PG_USER=
PG_PASSWORD=

# Répertoire des fichiers sources Excel (relatif à la racine du projet)
DATA_DIR=Service_Achat
